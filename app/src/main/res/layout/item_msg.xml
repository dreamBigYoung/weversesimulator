<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_msg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:longClickable="true"
    android:layout_marginTop="8dp"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/ivAvatarImage"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="left"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_circle"
        android:scaleType="centerCrop"
        android:src="@null" />

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/iv_msg"
            android:layout_width="229dp"
            android:layout_height="306dp"
            android:src="@null"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layout_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_msg"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/tv_original"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="いつかメンバーにもう会えなくなる日が来ると思うと、やっぱり寂しくなる😿"
                android:textColor="@color/color_msg_text"
                android:textIsSelectable="true"
                android:textSize="15sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_divder_line" />

            <TextView
                android:id="@+id/tv_translated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="一想到有一天会再也见不到推，就会很难过"
                android:textColor="@color/color_msg_text"
                android:textIsSelectable="true"
                android:textSize="15sp" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/tv_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="5dp"
        android:lines="1"
        android:text="12：56"
        android:textColor="#9AA0A6"
        android:textSize="12sp" />
</LinearLayout>